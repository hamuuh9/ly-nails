# Environment Variables
# Copy this file to .env.local and fill in the values

# Site URL (used for SEO and absolute URLs)
NEXT_PUBLIC_SITE_URL=https://ly-nails.vercel.app

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Maps API Key (optional, for embedded map)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Contact form email (optional, for server-side form handling)
# CONTACT_EMAIL=hello@ly-nails.co.uk
